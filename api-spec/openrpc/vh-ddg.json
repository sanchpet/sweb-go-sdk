      "resultDisable": {
        "description": "'fqdn' string название домена в Punycode\n\n'fqdnReadable' string читабельное название домена\n\n'isOnOurNs' bool домен на NS Spaceweb\n\n'expire' string дата истечения оплаты в формате dd.mm.yy",
        "name": "resultDisable",
        "schema": {
          "type": "object"
        }
      },
      "resultEnable": {
        "description": "'fqdn' string название домена в Punycode\n\n'fqdnReadable' string читабельное название домена\n\n'isOnOurNs' bool домен на NS Spaceweb\n\n'ip' string новый IP адрес",
        "name": "resultEnable",
        "schema": {
          "type": "object"
        }
      },
      "resultEnableInfo": {
        "description": "'domains' array массив доменов доступных для подключения услуги c элементами:\n\n'fqdn' string FQDN в Punycode,\n\n'fqdnReadable' string читабельный FQDN,\n\n'ssl' array|null информация по SSL сертификату домена или null при его отсутствии,\n\n'isOnOurNs' bool сомен на NS Spaceweb\n\n'price' float|int стоимость подключения услуги",
        "name": "resultEnableInfo",
        "schema": {
          "type": "object"
        }
      },
      "resultGetPrice": {
        "description": "стоимость услуги для текущего тарифного плана пользователя",
        "name": "resultGetPrice",
        "schema": {
          "type": "number"
        }
      },
      "resultIndex": {
        "description": "'fqdn' string название домена в Punycode\n\n'fqdnReadable' string читабельное название домена\n\n'ip' string|null IP адрес или null если услуга не подключена\n\n'expired' string|null дата истечения оплаты в формате yyyy-mm-dd или null если услуга не подключена\n\n'blocked' string|null дата блокировки услуги в формате yyyy-mm-dd или null если услуга не подключена\n\n'status' string статус слуги (disabled - не подключена, active - подключена, active_blocked - заблокирована клиентом, blocked - заблокирована за неуплату)",
        "name": "resultIndex",
        "schema": {
          "type": "array"
        }
      },
      "resultPriceWidget": {
        "description": "'current' float|int стоимость услуги на текущем тарифе\n\n'new' float|int стоимость услуги при переходе на тариф другой линейки",
        "name": "resultPriceWidget",
        "schema": {
          "type": "object"
        }
      }
